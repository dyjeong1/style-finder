# 네이버 쇼핑 검색 API 설정
# 네이버 개발자 센터에서 검색 API 애플리케이션을 만든 뒤 값을 채워주세요.
NAVER_SHOPPING_CLIENT_ID=
NAVER_SHOPPING_CLIENT_SECRET=
NAVER_SHOPPING_DISPLAY=30
NAVER_SHOPPING_TIMEOUT_SECONDS=3.0

# AI 비전 기반 착장 분석기 설정
VISION_OUTFIT_ANALYZER_ENABLED=false
VISION_OUTFIT_ANALYZER_PROVIDER=disabled
VISION_OUTFIT_ANALYZER_MODEL_NAME=
VISION_OUTFIT_ANALYZER_MAX_IMAGE_BYTES=2000000
VISION_OUTFIT_ANALYZER_TIMEOUT_SECONDS=20.0

# OpenAI Vision provider 설정
# 아래 OPENAI_VISION_* 이름도 동일하게 인식합니다.
OPENAI_API_KEY=
OPENAI_VISION_ENABLED=false
OPENAI_VISION_PROVIDER=openai
OPENAI_VISION_MODEL=gpt-4o

# Gemini Vision provider 설정
# 개인 개발/테스트는 Gemini 무료 티어를 우선 권장합니다.
GEMINI_API_KEY=
GEMINI_VISION_ENABLED=false
GEMINI_VISION_PROVIDER=gemini
GEMINI_VISION_MODEL=gemini-2.5-flash

# Ollama Vision provider 설정
# 로컬 무료 경로 권장: Ollama + gemma3:4b
OLLAMA_API_KEY=
OLLAMA_VISION_ENABLED=false
OLLAMA_VISION_PROVIDER=ollama
OLLAMA_VISION_MODEL=gemma3:4b
OLLAMA_API_BASE_URL=http://127.0.0.1:11434/api/chat
OLLAMA_VISION_TIMEOUT_SECONDS=90.0
